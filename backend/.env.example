# Curalink Backend Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017/curalink
# For production: mongodb+srv://username:password@cluster.mongodb.net/curalink

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Ollama LLM (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Options: mistral, llama3, mixtral, llama3:8b, mistral:7b

# NCBI PubMed (optional - increases rate limit)
# Get free API key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Contact email for OpenAlex polite pool
CONTACT_EMAIL=your-email@example.com
